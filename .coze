[project]
requires = ["python-3.12"]

[dev]
build = ["bash", "-c", "pip install -r requirements.txt && cd apps/dsa-web && pnpm install && pnpm run build"]
run = ["bash", "-c", "WEBUI_HOST=0.0.0.0 WEBUI_PORT=5000 python webui.py"]

[deploy]
build = ["bash", "-c", "pip install -r requirements.txt && cd apps/dsa-web && pnpm install && pnpm run build"]
run = ["bash", "-c", "WEBUI_HOST=0.0.0.0 WEBUI_PORT=5000 python webui.py"]
