[project]
requires = ["python-3.12"]

[dev]
build = ["bash", "-c", "pip3 install -r requirements.txt"]
run = ["python3", "-m", "uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "5000"]

[deploy]
build = ["bash", "-c", "pip3 install -r requirements.txt"]
run = ["python3", "-m", "uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "5000"]
