[project]
requires = ["python-3.12"]

[dev]
build = ["bash", "-c", "pip3 install -r requirements.txt"]
run = ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "5000"]

[deploy]
build = ["bash", "-c", "pip3 install -r requirements.txt && cd apps/dsa-web && pnpm install && pnpm run build"]
run = ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "5000"]
